{
  "name": "json-render-adapters",
  "private": true,
  "license": "Apache-2.0",
  "description": "Design system adapters and translator tool for json-render",
  "scripts": {
    "build": "turbo run build",
    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "type-check": "turbo run check-types",
    "check-types": "turbo run check-types",
    "generate": "tsx tools/design-system-generator/src/generate.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/react": "^19.2.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "turbo": "^2.7.4",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@10.29.3",
  "engines": {
    "node": ">=18"
  },
  "lint-staged": {
    "*.{ts,tsx}": "prettier --write"
  }
}
