{
  "name": "@json-render/carbon",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "description": "IBM Carbon Design System component library for @json-render/core. JSON becomes Carbon-styled React components.",
  "keywords": [
    "json",
    "ui",
    "react",
    "carbon",
    "ibm",
    "ai",
    "generative-ui",
    "llm",
    "renderer",
    "streaming",
    "components"
  ],
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./catalog": {
      "types": "./dist/catalog.d.ts",
      "import": "./dist/catalog.mjs",
      "require": "./dist/catalog.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@json-render/core": "workspace:*",
    "@json-render/react": "workspace:*",
    "@carbon/react": "^1.102.0",
    "@carbon/icons-react": "^11.76.0"
  },
  "devDependencies": {
    "@types/react": "19.2.3",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^4.0.0"
  }
}
